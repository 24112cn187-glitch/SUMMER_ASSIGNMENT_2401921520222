class Solution {
public:
    void moveZeroes(vector<int>& nums) {

        int n=nums.size();

        int i=0;
        

        while(i<n && nums[i]!=0) i++;

        for(int j=i+1;j<n;j++)
        {
            if(nums[j]!=0)
            {
                nums[i]=nums[j];
                i++;
            }
        }

        for(int k=i;k<n;k++)
        {
            nums[k]=0;
        }
        
    }
};
